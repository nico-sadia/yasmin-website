---
import BurgerMenu from "../components/BurgerMenu.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Yasmin's Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <nav><BurgerMenu /></nav>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #433169;
    --bg-light: #3d2b7a;
    --bubble-blue: #638eb6 --bubble-blue-dark: #4a6fa5;
    --accent: #638eb6;
    --text: #e8e0f5;
    --text-muted: #b8aed4;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    background-color: var(--bg);
    color: var(--text);
    font-family: "Nunito", sans-serif;
    overflow-x: hidden;
    padding: 0px 6px;
  }

  nav {
    z-index: 101;
    top: 0;
    left: 0;
    position: sticky;
    pointer: cursor;
  }
</style>
